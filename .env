# Local DC — Configuration
# These values are used by compose.yaml.
# Override by editing this file or exporting env vars.

# k3s version (must match a tag on docker.io/rancher/k3s)
K3S_VERSION=v1.35.5-k3s1

# Git repository for ArgoCD to sync from
REPO_URL=https://github.com/stevebestone/local-dc.git

# Git branch/tag for ArgoCD to track
TARGET_REVISION=main
