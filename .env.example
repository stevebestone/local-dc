# Copy to .env and adjust as needed.

# k3s image tag. Note: the container tag uses '-k3s1', not '+k3s1'.
# Find tags at https://hub.docker.com/r/rancher/k3s/tags
K3S_TAG=v1.35.5-k3s1

# Git source ArgoCD syncs the datacenter from.
# Point TARGET_REV at a branch to test changes before merging to main.
REPO_URL=https://github.com/stevebestone/local-dc.git
TARGET_REV=main
